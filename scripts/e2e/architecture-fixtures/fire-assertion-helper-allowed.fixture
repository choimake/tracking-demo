import { expectFiredHit } from "../tracking/index.js";

export async function allowed(ctx: any): Promise<void> {
  await expectFiredHit({
    act: ctx.act,
    exactCount: {
      countBefore: 0,
      eventId: "ev_fixture",
      expectedDelta: 1,
      kind: "event-increase",
      label: "fixture +1",
    },
    expectedPayload: { eventId: "ev_fixture", type: "event" },
    filter: { eventId: "ev_fixture", type: "event" },
    hitLabel: "fixture Hit",
    tracking: ctx.tracking,
  });
}
