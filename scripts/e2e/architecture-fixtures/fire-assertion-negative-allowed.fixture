import { expectNoHitsDuringObservation } from "../tracking/index.js";

export async function allowed(ctx: any): Promise<void> {
  const cursor = await ctx.tracking.captureHitCursor();
  await ctx.act();
  await expectNoHitsDuringObservation(
    ctx.tracking,
    { afterHitId: cursor, eventId: "ev_fixture", type: "event" },
    "fixture no Hit"
  );
}
