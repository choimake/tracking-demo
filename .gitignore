# Dependencies
node_modules/

# Runtime / local DB (起動時に再シードされる)
data/db.json
data/*.bak
data/*.tmp

# Environment / secrets
.env
.env.*
!.env.example

# Build / cache
dist/
build/
*.tsbuildinfo
.cache/

# Test / Playwright artifacts
test-results/
playwright-report/
playwright/.cache/
blob-report/
coverage/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS
.DS_Store
Thumbs.db

# Editor (個人設定は除外。ワークスペース共有の settings は残す)
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
*.code-workspace

# エディタ / エージェント用（リポジトリ外で管理）
.claude/
.cursor/
memory/
