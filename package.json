{
  "name": "tracking-demo",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "start": "tsx src/main.ts",
    "typecheck": "tsc --noEmit",
    "lint": "mise exec -- oxlint .",
    "lint:fix": "mise exec -- oxlint --fix .",
    "format": "mise exec -- oxfmt --check .",
    "format:fix": "mise exec -- oxfmt .",
    "check": "mise exec -- ultracite check",
    "fix": "mise exec -- ultracite fix",
    "knip": "mise exec -- knip",
    "deps": "mise exec -- depcruise --config .dependency-cruiser.cjs \"src/**/*.ts\" \"scripts/**/*.ts\"",
    "quality": "npm run typecheck && npm run e2e:architecture-check && npm run e2e:architecture-regression-check && npm run e2e:fire-assertion-helper-check && npm run e2e:config-check && npm run e2e:managed-session-check && npm run e2e:stack-check && npm run e2e:fixture-check && npm run e2e:scenario-teardown-check && npm run e2e:failure-diagnostics-check && npm run e2e:tracking-check && npm run e2e:observation-check && npm run e2e:cookie-helper-check && npm run e2e:selection-check && npm run e2e:scenario-catalog-check && npm run check && npm run knip",
    "secrets": "mise exec -- gitleaks detect --source . --verbose --redact",
    "secrets:staged": "mise exec -- gitleaks protect --staged --verbose --redact",
    "e2e": "playwright test",
    "e2e:cookie": "E2E_TAGS=cookie playwright test",
    "e2e:flake": "E2E_BROWSERS=chromium E2E_TAGS=cookie E2E_REPEAT=20 playwright test",
    "e2e:mobile": "E2E_MOBILE=1 playwright test",
    "e2e:video": "RECORD_VIDEO=all playwright test",
    "e2e:video:fail": "RECORD_VIDEO=on-failure playwright test",
    "e2e:architecture-check": "tsx scripts/e2e/architecture-check.ts && npm run deps",
    "e2e:architecture-regression-check": "tsx scripts/e2e/architecture.regression-check.ts",
    "e2e:fire-assertion-helper-check": "tsx scripts/e2e/tracking/fire-assertion-helper.regression-check.ts",
    "e2e:config-check": "tsx scripts/e2e/harness/config.regression-check.ts",
    "e2e:managed-session-check": "tsx scripts/e2e/harness/managed-session.regression-check.ts",
    "e2e:stack-check": "tsx scripts/e2e/harness/stack.regression-check.ts",
    "e2e:fixture-check": "tsx scripts/e2e/harness/fixture.regression-check.ts",
    "e2e:scenario-teardown-check": "tsx scripts/e2e/playwright/teardown.regression-check.ts",
    "e2e:failure-diagnostics-check": "tsx scripts/e2e/playwright/failure-diagnostics.regression-check.ts",
    "e2e:tracking-check": "tsx scripts/e2e/tracking/regression-check.ts",
    "e2e:observation-check": "tsx scripts/e2e/observation.regression-check.ts",
    "e2e:cookie-helper-check": "node --import tsx scripts/e2e/tests/cookie-helpers.regression-check.ts",
    "e2e:selection-check": "node --import tsx scripts/e2e/harness/scenario-selection.regression-check.ts",
    "e2e:scenario-catalog-check": "node --import tsx scripts/e2e/scenario-catalog.regression-check.ts",
    "e2e:bench": "tsx scripts/e2e/bench/run-bench.ts",
    "mutation": "tsx scripts/mutation/run.ts",
    "mutation:check": "MUTATION_VALIDATE_ONLY=1 node --import tsx scripts/mutation/run.ts"
  },
  "dependencies": {
    "esbuild": "^0.24.2",
    "express": "^4.21.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.2",
    "playwright": "^1.61.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "ultracite": "7.3.1"
  },
  "engines": {
    "node": ">=22"
  }
}
